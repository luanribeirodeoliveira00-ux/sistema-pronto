# =============================================================================
# Template Dashboard — Variáveis de ambiente
# =============================================================================
# Copie esse arquivo pra .env.local e preencha. Em produção (EasyPanel/Vercel),
# use o painel de Environment do orchestrator — NUNCA versionar .env.local.
# =============================================================================

# --- Supabase (OBRIGATÓRIO) -------------------------------------------------
# Pegue em https://supabase.com/dashboard/project/<seu-projeto>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# --- App --------------------------------------------------------------------
# URL pública do app. Em dev: http://localhost:3000. Em prod: https://seudominio
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Em prod com proxy reverso confiável (EasyPanel, Vercel, nginx), defina como 1
# pra confiar no X-Forwarded-For. Sem isso, rate limit por IP degrada.
TRUST_PROXY=

# --- Email (opcional — sem isso, fallback loga no terminal) -----------------
EMAIL_PROVIDER=supabase    # supabase | resend
RESEND_API_KEY=
EMAIL_FROM=Template Dashboard <noreply@example.com>

# --- Cron auth (OPCIONAL) ---------------------------------------------------
# Deixe VAZIO se você não usa cron externo. O recovery de mensagens já roda
# in-process via instrumentation.ts (lib/jobs/index.ts) a cada 60s.
#
# Só preencha se for chamar /api/cron/recover-messages de fora (Vercel Cron,
# UptimeRobot, etc.). Gere com `openssl rand -base64 32`. Se ficar vazio, a
# rota responde 401 e fica desabilitada — sem efeito no app.
CRON_SECRET=

# =============================================================================
# LLM Providers
# =============================================================================
LLM_PROVIDER=openai     # anthropic | openai

# Pelo menos UMA das duas precisa estar setada (a do LLM_PROVIDER escolhido).
ANTHROPIC_API_KEY=         # https://console.anthropic.com
OPENAI_API_KEY=            # https://platform.openai.com/api-keys
